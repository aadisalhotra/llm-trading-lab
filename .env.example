# Copy this to .env and fill in real keys. Never commit .env.

# LLM provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# News intelligence
# - Finnhub (free tier 60 calls/min) — primary source for per-stock headlines
#   the trading models see in their prompt. Alpha Vantage is the secondary.
# - NewsAPI (newsapi.org, free tier 100 requests/day) — primary source for
#   the single top macro headline rendered in the dashboard Market Brief.
#   Pulls from CNN/Reuters/CNBC/Bloomberg via top-headlines?category=business.
#   Cached hourly, so daily usage is ~24 calls. If unavailable, the Market
#   Brief falls back to Finnhub macro headlines.
# All three are optional — pipeline runs without news if none are set.
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=

# Alpaca brokerage (paper trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Email alerting (Gmail SMTP)
# - GMAIL_ADDRESS: the sending Gmail account (also appears in the From: line).
# - GMAIL_APP_PASSWORD: a 16-char Google "App Password" (NOT your login
#   password). Generate at https://myaccount.google.com/apppasswords with
#   2-Step Verification enabled. Spaces in the password are fine.
# Recipients live in config/settings.json under "alert_recipients" — not here.
# If either var is unset, the pipeline runs normally and email sends are
# skipped with a logged warning (never a crash).
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
