# Copy this to .env and fill in real keys. Never commit .env.

# LLM provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# News intelligence — primary provider is Finnhub (free tier 60 calls/min).
# Fallbacks are tried in order if Finnhub fails: Alpha Vantage, then NewsAPI.
# All three are optional — pipeline runs without news if none are set.
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=

# Alpaca brokerage (paper trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional alerting (email, future use)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
